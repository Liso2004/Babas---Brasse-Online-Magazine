NODE_ENV=production
PORT=8787
HOST=0.0.0.0
BABAS_ADMIN_EMAIL=admin@example.com
BABAS_ADMIN_PASSWORD_HASH=scrypt$replace-with-generated-salt$replace-with-generated-hash
DATABASE_URL=postgresql://babas:replace-me@postgres.example.com:5432/babas_brasse
BABAS_DATABASE_SSL=1
BABAS_DATABASE_SSL_REJECT_UNAUTHORIZED=1
BABAS_ADMIN_TOKEN=
BABAS_WEB_DIST_PATH=C:\babas-brasse-app\dist
BABAS_LOGIN_RATE_LIMIT=5
BABAS_PUBLIC_RATE_LIMIT=20
BABAS_RATE_WINDOW_MS=900000
BABAS_TRUST_PROXY=0
